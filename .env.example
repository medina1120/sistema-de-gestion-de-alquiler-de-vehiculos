# ========================================================
# .env.example - Variables de entorno del proyecto
# Copiar a .env y ajustar los valores para desarrollo local
# ========================================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=alquiler_vehiculos

# --- Backend (NestJS) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/alquiler_vehiculos?schema=public"
PORT=3001
NODE_ENV=development

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
